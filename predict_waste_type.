import numpy as np import cv2 from tensorflow.keras.models import load_model
model = load_model("waste_classifier.h5")
classes = ["Organic", "Plastic", "Paper", "Metal"]
image = cv2.imread("test.jpg") image = cv2.resize(image,(224,224)) image = image/255.0 image = np.expand_dims(image,axis=0)
prediction = model.predict(image)
print("Waste Type:", classes[np.argmax(prediction)])

